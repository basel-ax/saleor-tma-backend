{
  "name": "saleor-tma-backend",
  "version": "0.1.0",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/bundled.js --platform=neutral --target=es2020 --external:*.test.ts",
    "build:tsc": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "wrangler dev",
    "dev:local": "node scripts/dev.mjs",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "login": "wrangler login",
    "whoami": "wrangler whoami"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.75.0"
  }
}
